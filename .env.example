# Copy this file to .env and fill in your values
# Generate SECRET_KEY_BASE by running: docker run --rm slc_planner_ai bin/slc_planner_ai eval "IO.puts :crypto.strong_rand_bytes(48) |> Base.encode64"
# Or locally: mix phx.gen.secret

SECRET_KEY_BASE=your_64_char_secret_here

# The hostname users will use to access the app (default: localhost)
PHX_HOST=localhost
