<!DOCTYPE html>
<html lang="en">
  <head>
    {Application.get_env(:live_debugger, :live_debugger_tags)}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="SlcPlannerAi" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const darkMQ = window.matchMedia("(prefers-color-scheme: dark)");

        const setTheme = (pref) => {
          // Resolve "system" to the actual OS preference
          const resolved = pref === "system"
            ? (darkMQ.matches ? "dark" : "light")
            : pref;

          // Persist user preference (remove key when system so the storage
          // listener can detect "system" via a null/missing key)
          if (pref === "system") {
            localStorage.removeItem("phx:theme");
          } else {
            localStorage.setItem("phx:theme", pref);
          }

          // Always set data-theme so daisyUI CSS vars AND Tailwind dark: variant
          // both respond correctly in all three modes
          document.documentElement.setAttribute("data-theme", resolved);
          // Track user preference separately so the toggle indicator follows
          // the user's choice (system/light/dark) rather than the resolved theme
          document.documentElement.setAttribute("data-theme-pref", pref);
        };

        // Apply on first load
        setTheme(localStorage.getItem("phx:theme") || "system");

        // Re-resolve when OS preference changes (only matters when pref is "system")
        darkMQ.addEventListener("change", () => {
          if (!localStorage.getItem("phx:theme")) setTheme("system");
        });

        // Sync across browser tabs
        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme") setTheme(e.newValue || "system");
        });

        // Theme toggle buttons
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
